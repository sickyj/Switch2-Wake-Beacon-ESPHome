# OPTIONAL. You only need this if you hard-code Wi-Fi (the "headless" path in the
# README) instead of provisioning over Improv / the captive portal.
#
# Copy this file to `secrets.yaml`, fill in your details, and reference it from a
# `wifi:` block in your OWN config with `!secret wifi_ssid` / `!secret wifi_password`.
# (secrets.yaml is git-ignored so your credentials are never committed.)
wifi_ssid: "Your WiFi SSID"
wifi_password: "Your WiFi Password"
